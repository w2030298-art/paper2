)", "file_type": "code", "source_file": "/mnt/c/Users/22003/paper2/paper2/src/comm/channel/fading.py", "source_location": "L246"}, {"id": "channel_fading_rationale_1", "label": "Fading Channel Models  \u652f\u6301: - Rayleigh: \u7ecf\u5178\u745e\u5229\u8870\u843d (\u65e0\u76f4\u89c6\u5f84) - Rician: \u83b1\u65af\u8870\u843d (\u6709\u76f4\u89c6\u5f84) - Nak", "file_type": "rationale", "source_file": "/mnt/c/Users/22003/paper2/paper2/src/comm/channel/fading.py", "source_location": "L1"}, {"id": "channel_fading_rationale_18", "label": "\u745e\u5229\u8870\u843d\u4fe1\u9053      h ~ CN(0, 1)     |h|^2 ~ Exp(1) (\u6307\u6570\u5206\u5e03)      \u7528\u4e8e: \u57ce\u5e02\u5b8f\u57fa\u7ad9\u65e0\u76f4\u89c6\u5f84 (NLOS) \u573a\u666f", "file_type": "rationale", "source_file": "/mnt/c/Users/22003/paper2/paper2/src/comm/channel/fading.py", "source_location": "L18"}, {"id": "channel_fading_rationale_31", "label": "\u751f\u6210\u745e\u5229\u8870\u843d\u4fe1\u9053\u7cfb\u6570          Args:             size: \u8f93\u51fa\u5f62\u72b6          Returns:             h", "file_type": "rationale", "source_file": "/mnt/c/Users/22003/paper2/paper2/src/comm/channel/fading.py", "source_location": "L31"}, {"id": "channel_fading_rationale_45", "label": "\u8fd4\u56de\u4fe1\u9053\u589e\u76ca |h|^2 (\u670d\u4ece\u6307\u6570\u5206\u5e03)", "file_type": "rationale", "source_file": "/mnt/c/Users/22003/paper2/paper2/src/comm/channel/fading.py", "source_location": "L45"}, {"id": "channel_fading_rationale_50", "label": "\u83b1\u65af\u8870\u843d\u4fe1\u9053      h = sqrt(K/(K+1)) * exp(j*phi) + sqrt(1/(K+1)) * CN(0, 1)     |h|^2", "file_type": "rationale", "source_file": "/mnt/c/Users/22003/paper2/paper2/src/comm/channel/fading.py", "source_location": "L50"}, {"id": "channel_fading_rationale_68", "label": "\u751f\u6210\u83b1\u65af\u8870\u843d\u4fe1\u9053\u7cfb\u6570          Args:             size: \u8f93\u51fa\u5f62\u72b6          Returns:             h", "file_type": "rationale", "source_file": "/mnt