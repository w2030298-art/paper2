      "env": {
        "PYTHONPATH": "${workspaceFolder};${workspaceFolder}/src;${workspaceFolder}/scripts;${workspaceFolder}/rl_algorithms"
      },
      "args": [
        "--algorithm",
        "COMA",
        "--search-config",
        "configs/tuning/stage1_coma_mainline_a.yaml",
        "--mode",
        "starter",
        "--trials",
        "4",
        "--timesteps",
        "10000",
        "--seeds",
