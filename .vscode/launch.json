{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Mainline-A Full 17 Fresh",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/experiment_manager.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "PYTHONPATH": "${workspaceFolder};${workspaceFolder}/src;${workspaceFolder}/scripts;${workspaceFolder}/rl_algorithms"
      },
      "args": [
        "start",
        "--preset",
        "full17",
        "--environment-profile",
        "mainline-a",
        "--fresh"
      ]
    },
    {
      "name": "Resume",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/experiment_manager.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "PYTHONPATH": "${workspaceFolder};${workspaceFolder}/src;${workspaceFolder}/scripts;${workspaceFolder}/rl_algorithms"
      },
      "args": [
        "resume",
        "--run-id",
        "paper2_full_17_mainline_a"
      ]
    },
    {
      "name": "Status",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/experiment_manager.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "PYTHONPATH": "${workspaceFolder};${workspaceFolder}/src;${workspaceFolder}/scripts;${workspaceFolder}/rl_algorithms"
      },
      "args": [
        "status",
        "--run-id",
        "paper2_full_17_mainline_a"
      ]
    },
    {
      "name": "Export Results",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/experiment_manager.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "PYTHONPATH": "${workspaceFolder};${workspaceFolder}/src;${workspaceFolder}/scripts;${workspaceFolder}/rl_algorithms"
      },
      "args": [
        "export",
        "--run-id",
        "paper2_full_17_mainline_a",
        "--output",
        "results/benchmark_paper2_full_17_mainline_a.json"
      ]
    },
    {
      "name": "Direct Benchmark Dry Run",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/benchmark.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "PYTHONPATH": "${workspaceFolder};${workspaceFolder}/src;${workspaceFolder}/scripts;${workspaceFolder}/rl_algorithms"
      },
      "args": [
        "--all",
        "--environment-profile",
        "mainline-a",
        "--dry-run"
      ]
    },
    {
      "name": "Plot Latest",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/plot_results.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "PYTHONPATH": "${workspaceFolder};${workspaceFolder}/src;${workspaceFolder}/scripts;${workspaceFolder}/rl_algorithms"
      },
      "args": [
        "--input",
        "results/benchmark_paper2_full_17_mainline_a.json",
        "--output",
        "figures/",
        "--format",
        "pdf"
      ]
    },
    {
      "name": "Legacy Full 17 Fresh (Explicit Fallback)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/experiment_manager.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "PYTHONPATH": "${workspaceFolder};${workspaceFolder}/src;${workspaceFolder}/scripts;${workspaceFolder}/rl_algorithms"
      },
      "args": [
        "start",
        "--preset",
        "full17",
        "--environment-profile",
        "legacy",
        "--run-id",
        "paper2_full_17_legacy_fallback",
        "--fresh"
      ]
    },
    {
      "name": "Experiment List",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/experiment_manager.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "PYTHONPATH": "${workspaceFolder};${workspaceFolder}/src;${workspaceFolder}/scripts;${workspaceFolder}/rl_algorithms"
      },
      "args": [
        "list"
      ]
    }
  ]
}
