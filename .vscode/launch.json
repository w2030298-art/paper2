      "name": "Stage-1 Tune PPO Starter",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/tune_mainline_a_stage1.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "PYTHONPATH": "${workspaceFolder};${workspaceFolder}/src;${workspaceFolder}/scripts;${workspaceFolder}/rl_algorithms"
      },
      "args": [
        "--algorithm",
        "PPO",
        "--search-config",
        "configs/tuning/stage1_ppo_mainline_a.yaml",
        "--mode",
        "starter",
        "--trials",
        "4",
        "--timesteps",
        "10000",
        "--seeds",
        "42",
        "--environment-profile",
        "mainline-a",
        "--device",
        "auto",
        "--output-dir",
        "outputs/stage1"
      ]
    },
