      "name": "Stage-1 Tune COMA Starter",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/tune_mainline_a_stage1.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
