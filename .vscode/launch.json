      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/experiment_manager.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "PYTHONPATH": "${workspaceFolder};${workspaceFolder}/src;${workspaceFolder}/scripts;${workspaceFolder}/rl_algorithms"
      },
      "args": [
