{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "🧪 Experiment Start/Resume (Quick)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/experiment_manager.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "PYTHONPATH": "${workspaceFolder};${workspaceFolder}/src;${workspaceFolder}/scripts;${workspaceFolder}/rl_algorithms"
      },
      "args": [
        "start",
        "--run-id",
        "vscode_quick",
        "--name",
        "VSCode Quick Benchmark",
        "--algorithms",
        "GRPO",
        "PPO",
        "SAC",
        "--timesteps",
        "5000",
        "--seed",
        "42",
        "--device",
        "auto",
        "--eval-episodes",
        "3"
      ]
    },
    {
      "name": "🧪 Experiment Resume",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/experiment_manager.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "PYTHONPATH": "${workspaceFolder};${workspaceFolder}/src;${workspaceFolder}/scripts;${workspaceFolder}/rl_algorithms"
      },
      "args": [
        "resume",
        "--run-id",
        "vscode_quick"
      ]
    },
    {
      "name": "⏹ Experiment Stop",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/experiment_manager.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "PYTHONPATH": "${workspaceFolder};${workspaceFolder}/src;${workspaceFolder}/scripts;${workspaceFolder}/rl_algorithms"
      },
      "args": [
        "stop",
        "--run-id",
        "vscode_quick"
      ]
    },
    {
      "name": "📊 Experiment Status",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/experiment_manager.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "PYTHONPATH": "${workspaceFolder};${workspaceFolder}/src;${workspaceFolder}/scripts;${workspaceFolder}/rl_algorithms"
      },
      "args": [
        "status",
        "--run-id",
        "vscode_quick"
      ]
    },
    {
      "name": "📋 Experiment List",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/experiment_manager.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "PYTHONPATH": "${workspaceFolder};${workspaceFolder}/src;${workspaceFolder}/scripts;${workspaceFolder}/rl_algorithms"
      },
      "args": [
        "list"
      ]
    },
    {
      "name": "📦 Experiment Export Results",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/experiment_manager.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "PYTHONPATH": "${workspaceFolder};${workspaceFolder}/src;${workspaceFolder}/scripts;${workspaceFolder}/rl_algorithms"
      },
      "args": [
        "export",
        "--run-id",
        "vscode_quick"
      ]
    }
  ]
}
