      "args": [
        "--matrix",
        "configs/paper2_main_experiment_matrix.yaml",
        "--scenario-matrix",
        "configs/paper2_scenario_matrix.yaml",
        "--level",
        "L1_screening",
        "--dry-run",
        "--output",
        "results/paper2_main_matrix/dry_run_manifest.json",
